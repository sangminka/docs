# ==============================================================================
# {{PROJECT_NAME}} - 개발 환경 (Development)
# ==============================================================================
# 이 파일은 개발 환경용 설정 템플릿입니다.
# 실제 사용 시 application-dev.properties로 복사한 뒤 값을 수정하세요.
#
#   cp application-dev.properties.example application-dev.properties
#
# 활성화: application.properties에 spring.profiles.active=dev 추가
# 주의: application-dev.properties는 .gitignore에 등록하여 Git 커밋을 방지하세요.
# ==============================================================================


# ------------------------------------------------------------------------------
# 1. 서버 설정
# ------------------------------------------------------------------------------

# 서버 포트
server.port=8080

# 세션 타임아웃 (개발 편의를 위해 60분)
server.servlet.session.timeout=60m


# ------------------------------------------------------------------------------
# 2. 데이터베이스 설정 (MySQL - 로컬)
# ------------------------------------------------------------------------------

# 로컬 MySQL 접속 URL
spring.datasource.url=jdbc:mysql://localhost:3306/{{project}}_db?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true

# 로컬 MySQL 사용자명
spring.datasource.username={{project}}_user

# 로컬 MySQL 비밀번호
# 개발 환경에서도 환경변수 사용을 권장합니다.
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:CHANGE_ME}

# MySQL 드라이버
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# HikariCP 커넥션 풀 (개발: 최소 설정)
spring.datasource.hikari.maximum-pool-size=5
spring.datasource.hikari.minimum-idle=2
spring.datasource.hikari.connection-timeout=5000


# ------------------------------------------------------------------------------
# 3. JPA / Hibernate 설정
# ------------------------------------------------------------------------------

# DDL 자동 관리: update (개발 중 엔티티 변경 자동 반영)
spring.jpa.hibernate.ddl-auto=update

# SQL 로그 출력 (개발: 활성화)
spring.jpa.show-sql=true

# SQL 포맷팅 (가독성 향상)
spring.jpa.properties.hibernate.format_sql=true

# MySQL 방언
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# open-in-view 비활성화 (권장)
spring.jpa.open-in-view=false


# ------------------------------------------------------------------------------
# 4. Redis 세션 저장소 설정 (로컬)
# ------------------------------------------------------------------------------

# 로컬 Redis
spring.data.redis.host=localhost
spring.data.redis.port=6379

# Redis 비밀번호 (로컬 개발 시 미설정이 일반적)
# spring.data.redis.password=

# Spring Session 저장소 타입
spring.session.store-type=redis

# Redis 세션 네임스페이스
spring.session.redis.namespace={{project}}:session:dev

# 세션 타임아웃 (3600초 = 60분, 서버 세션 타임아웃과 동일)
spring.session.timeout=3600

# Redis 세션 flush 모드
spring.session.redis.flush-mode=on-save


# ------------------------------------------------------------------------------
# 5. Mustache 템플릿 설정
# ------------------------------------------------------------------------------

# 템플릿 파일 확장자
spring.mustache.suffix=.mustache

# Request Attributes 노출
spring.mustache.servlet.expose-request-attributes=true


# ------------------------------------------------------------------------------
# 6. Claude API 설정 (LLM)
# ------------------------------------------------------------------------------

# Claude API 키 (반드시 환경변수 사용)
claude.api.key=${CLAUDE_API_KEY:}

# Claude 모델명
claude.api.model=claude-sonnet-4-6

# API 호출 타임아웃 (개발: 10초 - 디버깅 여유)
claude.api.timeout=10000

# 최대 토큰 수
claude.api.max-tokens=1024

# Claude API 베이스 URL
claude.api.base-url=https://api.anthropic.com

# API 버전
claude.api.version=2023-06-01


# ------------------------------------------------------------------------------
# 7. 파일 업로드 제한
# ------------------------------------------------------------------------------

spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=20MB
spring.servlet.multipart.enabled=true


# ------------------------------------------------------------------------------
# 8. 로깅 설정 (개발: 상세 로그)
# ------------------------------------------------------------------------------

# 루트 로그 레벨
logging.level.root=INFO

# Spring 프레임워크
logging.level.org.springframework=INFO

# Spring Security (인증/인가 디버깅)
logging.level.org.springframework.security=DEBUG

# JPA/Hibernate
logging.level.org.hibernate=INFO

# SQL 바인딩 파라미터 출력 (개발 시 쿼리 파라미터 확인 가능)
logging.level.org.hibernate.type.descriptor.sql.BasicBinder=TRACE

# 애플리케이션 로그 레벨 (개발: DEBUG)
logging.level.{{BASE_PACKAGE}}=DEBUG

# 콘솔 로그 패턴
logging.pattern.console=%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n


# ------------------------------------------------------------------------------
# 9. 에러 페이지 설정 (개발: 상세 정보 노출)
# ------------------------------------------------------------------------------

# 에러 메시지 포함
server.error.include-message=always

# 스택 트레이스 포함 (개발: 디버깅 용도)
server.error.include-stacktrace=always

# Whitelabel 에러 페이지 비활성화
server.error.whitelabel.enabled=false

# 인코딩 설정
server.servlet.encoding.charset=UTF-8
server.servlet.encoding.force=true
server.servlet.encoding.enabled=true
